    <script>
        // --- Utility: Chart.js Label Wrapping Requirement ---
        const formatLabel = (label) => {
            if (label.length <= 16) return label;
            const words = label.split(' ');
            const lines = [];
            let currentLine = words[0];
            for (let i = 1; i < words.length; i++) {
                if (currentLine.length + words[i].length + 1 <= 16) {
                    currentLine += ' ' + words[i];
                } else {
                    lines.push(currentLine);
                    currentLine = words[i];
                }
            }
            lines.push(currentLine);
            return lines;
        };

        // --- Utility: Chart.js Tooltip Configuration Requirement ---
        const globalTooltipConfig = {
            tooltip: {
                callbacks: {
                    title: function(tooltipItems) {
                        const item = tooltipItems[0];
                        let label = item.chart.data.labels[item.dataIndex];
                        if (Array.isArray(label)) {
                            return label.join(' ');
                        } else {
                            return label;
                        }
                    }
                }
            }
        };

        // --- Chart 1: Market Growth (Line) ---
        const ctxGrowth = document.getElementById('marketGrowthChart').getContext('2d');
        new Chart(ctxGrowth, {
            type: 'line',
            data: {
                labels: ['2023', '2024', '2025', '2026 (Est)', '2027 (Proj)', '2028 (Proj)'],
                datasets: [{
                    label: 'Market Value (£ Millions)',
                    data: [280, 360, 480, 650, 810, 950],
                    borderColor: '#0369a1', // sky-700
                    backgroundColor: 'rgba(3, 105, 161, 0.1)',
                    borderWidth: 3,
                    pointBackgroundColor: '#ea580c', // orange-600
                    pointRadius: 5,
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    ...globalTooltipConfig,
                    legend: { display: false }
                },
                scales: {
                    y: { 
                        beginAtZero: true, 
                        grid: { color: '#e7e5e4' }, // stone-200
                        ticks: { color: '#57534e' } // stone-500
                    },
                    x: { 
                        grid: { display: false },
                        ticks: { color: '#57534e' }
                    }
                }
            }
        });

        // --- Chart 2: Flavor Share (Doughnut) ---
        const ctxFlavor = document.getElementById('flavorChart').getContext('2d');
        new Chart(ctxFlavor, {
            type: 'doughnut',
            data: {
                labels: [formatLabel('Mint & Menthol'), formatLabel('Fruit Fusions'), formatLabel('Coffee & Dessert'), formatLabel('Unflavored Base')],
                datasets: [{
                    data: [65, 25, 8, 2],
                    backgroundColor: [
                        '#0284c7', // sky-600 (Mint)
                        '#f59e0b', // amber-500 (Fruit)
                        '#78716c', // stone-500 (Coffee)
                        '#d6d3d1'  // stone-300 (Unflavored)
                    ],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '70%',
                plugins: {
                    ...globalTooltipConfig,
                    legend: { 
                        position: 'bottom',
                        labels: { color: '#44403c', padding: 20, usePointStyle: true }
                    }
                }
            }
        });

        // --- Chart 3: Channel Share (Horizontal Bar) ---
        const ctxChannel = document.getElementById('channelChart').getContext('2d');
        new Chart(ctxChannel, {
            type: 'bar',
            data: {
                labels: [
                    formatLabel('Convenience Stores'), 
                    formatLabel('Online Direct & Subs'), 
                    formatLabel('Specialist Vape Stores'), 
                    formatLabel('Grocery Supermarkets'), 
                    formatLabel('Forecourts')
                ],
                datasets: [{
                    label: 'Volume Share (%)',
                    data: [55, 25, 12, 5, 3],
                    backgroundColor: '#0ea5e9', // sky-500
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    ...globalTooltipConfig,
                    legend: { display: false }
                },
                scales: {
                    x: { 
                        beginAtZero: true, 
                        grid: { color: '#e7e5e4' },
                        ticks: { color: '#57534e' }
                    },
                    y: { 
                        grid: { display: false },
                        ticks: { color: '#44403c', font: { weight: '500' } }
                    }
                }
            }
        });

        // --- Chart 4: Strength Distribution (Grouped Bar) ---
        const ctxStrength = document.getElementById('strengthChart').getContext('2d');
        new Chart(ctxStrength, {
            type: 'bar',
            data: {
                labels: ['Low (<6mg)', 'Regular (6-9mg)', 'Strong (10-14mg)', 'Extreme (15mg+)'],
                datasets: [
                    {
                        label: 'VELO',
                        data: [30, 50, 20, 0],
                        backgroundColor: '#2563eb' // blue-600
                    },
                    {
                        label: 'ZYN',
                        data: [40, 45, 15, 0],
                        backgroundColor: '#0ea5e9' // sky-500
                    },
                    {
                        label: 'Nordic Spirit',
                        data: [20, 60, 20, 0],
                        backgroundColor: '#0d9488' // teal-600
                    },
                    {
                        label: 'Disruptors',
                        data: [5, 10, 25, 60],
                        backgroundColor: '#ea580c' // orange-600
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    ...globalTooltipConfig,
