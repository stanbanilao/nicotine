        function updateBrandProfile(brandKey) {
            // Update buttons
            document.querySelectorAll('.brand-btn').forEach(btn => {
                if(btn.dataset.brand === brandKey) {
                    btn.classList.remove('brand-btn-inactive');
                    btn.classList.add('brand-btn-active');
                } else {
                    btn.classList.remove('brand-btn-active');
                    btn.classList.add('brand-btn-inactive');
                }
            });

            // Update content
            const data = brandData[brandKey];
            document.getElementById('brand-name').innerText = data.name;
            document.getElementById('brand-target').innerText = data.target;
            document.getElementById('brand-positioning').innerText = data.positioning;
            document.getElementById('brand-price').innerText = data.price;
            document.getElementById('brand-strength-text').innerText = data.strength;
            document.getElementById('brand-packaging').innerText = data.packaging;
            
            // Update color indicator
            const indicator = document.getElementById('brand-color-indicator');
            indicator.className = `w-4 h-4 rounded-full ${data.color}`;
        }

        // --- Interactive State Management: Regulatory Tabs ---
        function switchTab(tabId) {
            // Update tabs
            document.querySelectorAll('.reg-tab').forEach(tab => {
                if(tab.dataset.tab === tabId) {
                    tab.classList.remove('tab-inactive');
                    tab.classList.add('tab-active');
                } else {
                    tab.classList.remove('tab-active');
                    tab.classList.add('tab-inactive');
                }
            });

            // Update content visibility
            document.querySelectorAll('.tab-content').forEach(content => {
                content.classList.add('hidden');
            });
            document.getElementById(`tab-content-${tabId}`).classList.remove('hidden');
        }

    </script>
